<%@ Page Title="Bookings" Language="C#" MasterPageFile="~/pages/Admin.Master"AutoEventWireup="true" CodeFile="bookings.aspx.cs"Inherits="KumariCinema.Admin.bookings" %><asp:Content ID="Content2" ContentPlaceHolderID="ContentPlaceHolder1" runat="server">  <div class="page-title d-flex justify-content-between align-items-center">    <h2><i class="fas fa-ticket-alt"></i> Bookings</h2>    <button type="button" class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#addBookingModal"><i class="fas fa-plus"></i> Add Booking</button>  </div>  <div class="card mb-3"><div class="card-body"><input type="text" id="searchInput" class="form-control" placeholder="Search bookings..." /></div></div>  <div class="card"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Booking ID</th><th>User</th><th>Show</th><th>Total Amount</th><th class="text-end">Actions</th></tr></thead><tbody>    <asp:Repeater ID="bookingsRepeater" runat="server"><ItemTemplate><tr>      <td><%# Eval("BookingId") %></td><td><%# Eval("UserDisplay") %></td><td><%# Eval("ShowDisplay") %></td><td><%# Eval("TotalAmount") %></td>      <td class="text-end">        <button type="button" class="btn btn-sm btn-warning me-1" data-bs-toggle="modal" data-bs-target="#editBookingModal" onclick="editBooking('<%# Eval("BookingId") %>','<%# Eval("UserId") %>','<%# Eval("ShowId") %>','<%# Eval("TotalAmount") %>')"><i class="fas fa-edit"></i> Edit</button>        <button type="button" class="btn btn-sm btn-danger" onclick="deleteBooking('<%# Eval("BookingId") %>')"><i class="fas fa-trash"></i> Delete</button>      </td>    </tr></ItemTemplate></asp:Repeater>  </tbody></table></div></div>  <div class="modal fade" id="addBookingModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Add Booking</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body">    <div class="mb-3" style="display:none;"><label class="form-label">Booking ID</label><asp:TextBox ID="bookingIdInput" runat="server" CssClass="form-control"></asp:TextBox></div>    <div class="mb-3"><label class="form-label">User ID</label><asp:TextBox ID="userIdInput" runat="server" CssClass="form-control"></asp:TextBox></div>    <div class="mb-3"><label class="form-label">Show</label><asp:DropDownList ID="showDropdown" runat="server" CssClass="form-select"></asp:DropDownList></div>    <div class="mb-3"><label class="form-label">Total Amount</label><asp:TextBox ID="totalAmountInput" runat="server" CssClass="form-control" TextMode="Number"></asp:TextBox></div>  </div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button><asp:Button ID="saveBookingButton" runat="server" Text="Save Booking" CssClass="btn btn-primary-custom" OnClick="SaveBooking_Click" /></div></div></div></div>  <div class="modal fade" id="editBookingModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Edit Booking</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body">    <asp:HiddenField ID="editBookingIdField" runat="server" />    <div class="mb-3" style="display:none;"><label class="form-label">Booking ID</label><asp:TextBox ID="editBookingIdInput" runat="server" CssClass="form-control" ReadOnly="true"></asp:TextBox></div>    <div class="mb-3"><label class="form-label">User ID</label><asp:TextBox ID="editUserIdInput" runat="server" CssClass="form-control"></asp:TextBox></div>    <div class="mb-3"><label class="form-label">Show</label><asp:DropDownList ID="editShowDropdown" runat="server" CssClass="form-select"></asp:DropDownList></div>    <div class="mb-3"><label class="form-label">Total Amount</label><asp:TextBox ID="editTotalAmountInput" runat="server" CssClass="form-control" TextMode="Number"></asp:TextBox></div>  </div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button><asp:Button ID="updateBookingButton" runat="server" Text="Update Booking" CssClass="btn btn-primary-custom" OnClick="UpdateBooking_Click" /></div></div></div></div></asp:Content><asp:Content ID="Content3" ContentPlaceHolderID="scripts" runat="server"><script>function editBooking(id, userId, showId, amount) {  document.getElementById('<%= editBookingIdInput.ClientID %>').value = id;  document.getElementById('<%= editBookingIdField.ClientID %>').value = id;  document.getElementById('<%= editUserIdInput.ClientID %>').value = userId;  document.getElementById('<%= editShowDropdown.ClientID %>').value = showId;  document.getElementById('<%= editTotalAmountInput.ClientID %>').value = amount;}function deleteBooking(id) {  showConfirm('', function () {    const form = document.getElementById('form1');    const f = document.createElement('input');    f.type = 'hidden'; f.name = 'deleteBookingId'; f.value = id;    form.appendChild(f); form.submit();                });            }document.getElementById('searchInput').addEventListener('keyup', function () {  const v = this.value.toLowerCase();  document.querySelectorAll('table tbody tr').forEach(r => r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none');});setActiveLink('bookingsLink');</script></asp:Content>